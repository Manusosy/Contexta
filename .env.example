# Flask Environment
FLASK_ENV=development
FLASK_APP=app.py

# Security
# MUST change this in production!
SECRET_KEY=dev_secret_key_change_in_production

# Default Admin Credentials
# These will be used to seed the initial admin user during first startup
ADMIN_USER=admin
ADMIN_PASSWORD=password

# Database Config (Optional, defaults to sqlite:///contexta.db)
# DATABASE_URL=postgresql://user:password@localhost/contexta

# Email / SMTP Configuration
MAIL_SERVER=mail.kazinikazi.co.ke
MAIL_PORT=465
MAIL_USE_SSL=True
MAIL_USERNAME=noreply@kazinikazi.co.ke
MAIL_PASSWORD=your_email_password_here
MAIL_DEFAULT_SENDER=noreply@kazinikazi.co.ke
